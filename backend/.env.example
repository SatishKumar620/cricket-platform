# ── CricketStream Backend Config ─────────────────────────────────────────────
# Copy this file to .env and fill in values

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cricket Data Sources (priority order) ────────────────────────────────────
# Source 1: CricketData.org (FREE — 100 req/day)
# Get key: https://cricketdata.org → Register → Dashboard
CRICKETDATA_KEY=
CRICKETDATA_INTERVAL=900        # 15 min poll = 96 req/day (safe under 100 limit)

# Source 2: CricAPI (FREE — 100 req/day)
# Get key: https://cricapi.com → Sign Up → API Key
CRICAPI_KEY=
CRICAPI_INTERVAL=900            # 15 min poll = 96 req/day

# Source 3: Cricbuzz scraper — no key needed, always on
CRICBUZZ_INTERVAL=8             # 8 sec poll

# Source 4: Mock data — always on as final fallback
MOCK_INTERVAL=5                 # 5 sec between mock ball events

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" = local Mistral (free, needs ollama installed)
# "groq"   = Groq cloud API (free 14400 req/day — RECOMMENDED for hackathon)
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_BASE_URL=http://localhost:11434

# Groq (fastest free LLM — get key at https://console.groq.com)
GROQ_API_KEY=

# ── TTS Provider ─────────────────────────────────────────────────────────────
# "kokoro"     = local Kokoro-82M (free, needs Docker)
# "elevenlabs" = ElevenLabs cloud (free 10k chars/month)
TTS_PROVIDER=kokoro
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=am_adam            # am_adam | am_michael | bf_emma | af_sky

# ElevenLabs (optional — get key at https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Translation ───────────────────────────────────────────────────────────────
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_KEY=             # optional — get at https://libretranslate.com
