# Copy to .env.local and update for your environment

# ── Local development ─────────────────────────────────────────────────────────
VITE_WS_SCORES=ws://localhost:8000/ws/scores
VITE_WS_AUDIO=ws://localhost:8000/tts/ws/audio
VITE_API_BASE=http://localhost:8000

# ── Production (replace with your deployed backend URL) ──────────────────────
# VITE_WS_SCORES=wss://your-backend.onrender.com/ws/scores
# VITE_WS_AUDIO=wss://your-backend.onrender.com/tts/ws/audio
# VITE_API_BASE=https://your-backend.onrender.com

# ── Docker (accessing backend from browser, not from container) ───────────────
# VITE_WS_SCORES=ws://localhost:8000/ws/scores
# VITE_WS_AUDIO=ws://localhost:8000/tts/ws/audio
# VITE_API_BASE=http://localhost:8000
